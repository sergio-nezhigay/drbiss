<style>
  .wcu-section {
    position: relative;
    overflow: hidden;
  }

  .wcu-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .wcu-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--announcement-bar-bg);
    margin: 0 0 0.75rem;
  }

  .wcu-heading {
    margin: 0 0 1rem;
  }

  .wcu-subtitle {
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.65;
    opacity: 0.75;
  }

  .wcu-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .wcu-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .wcu-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .wcu-card {
    background: #f5f9f3;
    border: 1px solid #d6e8cf;
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
  }

  .wcu-icon-circle {
    width: 66px;
    height: 66px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .wcu-card-title {
    font-weight: 700;
    margin: 0 0 0.5rem;
    font-size: 1rem;
    line-height: 1.3;
  }

  .wcu-card-desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.65;
    opacity: 0.75;
  }
</style>

<section
  class="wcu-section bg-scheme-background text-scheme-text"
  data-color-scheme="{{ section.settings.color_scheme }}"
>
  <div class="wcu-inner px-section w-full max-w-site mx-auto py-section-vertical-spacing">
    <div class="wcu-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="wcu-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="wcu-heading font-heading heading-standard {{ settings.heading_drop_shadow_style }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="wcu-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ul class="wcu-grid" style="list-style:none;margin:0;padding:0;">
        {%- for block in section.blocks -%}
          <li class="wcu-card" {{ block.shopify_attributes }}>
            <div
              class="wcu-icon-circle"
              style="background-color: {{ block.settings.icon_bg }};"
              aria-hidden="true"
            >
              {{ block.settings.emoji }}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="wcu-card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="wcu-card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clean science. Real results."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Founded by chemists and engineers who asked: why does soap need 30 ingredients? We kept only what matters."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "scheme1", "label": "Scheme 1" },
        { "value": "scheme2", "label": "Scheme 2" },
        { "value": "scheme3", "label": "Scheme 3" },
        { "value": "scheme4", "label": "Scheme 4" },
        { "value": "scheme5", "label": "Scheme 5" }
      ],
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Icon (emoji)",
          "default": "🔬"
        },
        {
          "type": "color",
          "id": "icon_bg",
          "label": "Icon background color",
          "default": "#dde8f5"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Science-backed formulas"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Developed by university professors in chemistry & engineering — not marketing departments."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "emoji": "🔬",
            "icon_bg": "#dde8f5",
            "title": "Science-backed formulas",
            "description": "Developed by university professors in chemistry & engineering — not marketing departments."
          }
        },
        {
          "type": "feature",
          "settings": {
            "emoji": "🌿",
            "icon_bg": "#dff0de",
            "title": "Zero palm oil. Ever.",
            "description": "Palm-free by principle. We use coconut oil, olive oil & glycerin for a lather that's good for you and the planet."
          }
        },
        {
          "type": "feature",
          "settings": {
            "emoji": "💧",
            "icon_bg": "#daeef7",
            "title": "Transparently simple",
            "description": "No parabens, no SLS, no dyes, no alcohols. Every ingredient earns its place — nothing hidden."
          }
        },
        {
          "type": "feature",
          "settings": {
            "emoji": "♻️",
            "icon_bg": "#fef3d0",
            "title": "Sustainably minded",
            "description": "Shorter, cleaner formulas mean less waste. Based in Austin, TX — crafted with care from the ground up."
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
